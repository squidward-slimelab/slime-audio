[Unit]
Description=Serve the SlimeAudio web dashboard
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/squidward/.openclaw/workspace/slime-audio
ExecStart=/usr/bin/python3 /home/squidward/.openclaw/workspace/slime-audio/scripts/slime_audio_web.py --host 0.0.0.0 --port 8765
Restart=always
RestartSec=2

[Install]
WantedBy=default.target

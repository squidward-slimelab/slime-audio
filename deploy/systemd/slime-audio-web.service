[Unit]
Description=Serve the SlimeAudio web dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=squidward
WorkingDirectory=/home/squidward/.openclaw/workspace/slime-audio
ExecStart=/home/squidward/.openclaw/workspace/slime-audio/.venv/bin/python /home/squidward/.openclaw/workspace/slime-audio/scripts/slime_audio_web.py --host 0.0.0.0 --port 8765
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target

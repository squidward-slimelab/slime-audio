[Unit]
Description=Extend the live SlimeAudio set behind the playhead (proactive buffer)
After=network-online.target

[Service]
Type=oneshot
User=squidward
WorkingDirectory=/home/squidward/.openclaw/workspace/slime-audio
ExecStart=/home/squidward/.openclaw/workspace/slime-audio/.venv/bin/python /home/squidward/.openclaw/workspace/slime-audio/scripts/slime_audio_autodj.py extend --target-length-ms 0
Nice=10
